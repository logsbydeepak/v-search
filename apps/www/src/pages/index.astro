---
import "../styles/global.css";
import Logo from "../components/Logo.astro";
import ThemeHead from "../components/ThemeHead.astro";

const chips = ["Trending", "News", "Sports", "Finance", "Technology", "Science"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
    <ThemeHead />
    <title>Quickly - Search the web, fast.</title>
  </head>
  <body class="min-h-screen bg-[#f5f2ee] text-[#141210] transition-colors duration-200 dark:bg-[#0f0e0c] dark:text-[#f0ede8]">
    <div class="flex min-h-screen flex-col bg-[#f5f2ee] dark:bg-[#0f0e0c]">
      <nav class="flex items-center justify-between px-7 py-4">
        <div></div>
        <div class="flex items-center gap-3">
          <button data-theme-toggle class="flex items-center gap-1.5 rounded-full border-[1.5px] border-black/[0.09] bg-white/70 px-3.5 py-1.5 font-dm text-[13px] font-medium text-[#4a4540] backdrop-blur-sm transition-all duration-150 hover:border-black/20 hover:text-[#141210] dark:border-white/[0.08] dark:bg-[#1e1c18]/85 dark:text-[#b8b0a5] dark:hover:border-white/20 dark:hover:text-[#f0ede8]">
            <svg data-theme-moon width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
            <svg data-theme-sun class="hidden" width="15" height="15" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path></svg>
            <span data-theme-label>Dark</span>
          </button>
          <button class="rounded-full bg-[var(--accent)] px-5 py-1.5 font-dm text-[13px] font-semibold text-white transition-opacity duration-150 hover:opacity-85">Sign in</button>
        </div>
      </nav>

      <main class="flex flex-1 flex-col items-center justify-center px-6 pb-[18vh]">
        <div class="mb-10 flex animate-fade-up flex-col items-center gap-1">
          <Logo size="lg" />
          <p class="mt-2 text-sm font-light tracking-[0.12em] text-[#8a837a] dark:text-[#6e6760]">Search the web, fast.</p>
        </div>

        <form data-search-form class="w-full max-w-[600px] animate-fade-up delay-1">
          <div data-search-shell class="relative w-full">
            <div class="flex h-14 items-center gap-2.5 rounded-[28px] border-[1.5px] border-black/[0.09] bg-white/70 px-5 shadow-sm backdrop-blur-md transition-all duration-150 focus-within:border-[var(--accent)] focus-within:shadow-[0_0_0_3px_var(--accent-glow),0_4px_16px_rgba(0,0,0,0.08)] dark:border-white/[0.08] dark:bg-[#1e1c18]/85">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="shrink-0 opacity-40"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"></circle><path d="M13 13L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
              <input data-search-input autofocus type="text" placeholder="Search the web, fast." class="flex-1 border-none bg-transparent font-dm text-[17px] text-[#141210] caret-[var(--accent)] outline-none placeholder:text-[#8a837a] dark:text-[#f0ede8] dark:placeholder:text-[#6e6760]" />
              <button data-clear-search type="button" class="hidden rounded-full p-1 text-[#8a837a] transition-colors duration-150 hover:text-[#141210] dark:hover:text-[#f0ede8]"><svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 2L12 12M12 2L2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg></button>
              <div class="h-5 w-px shrink-0 bg-black/10 dark:bg-white/10"></div>
              <button type="submit" class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[var(--accent)] transition-all duration-100 hover:opacity-85 active:scale-95"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="4.5" stroke="white" stroke-width="1.8"></circle><path d="M10.5 10.5L14 14" stroke="white" stroke-width="1.8" stroke-linecap="round"></path></svg></button>
            </div>
            <div data-suggestions class="absolute left-0 right-0 top-full z-50 hidden overflow-hidden rounded-b-[20px] border-[1.5px] border-t border-[var(--accent)] border-t-black/5 bg-white/95 shadow-lg backdrop-blur-md dark:border-t-white/5 dark:bg-[#1e1c18]/97"></div>
          </div>

          <div class="mt-5 flex justify-center gap-2.5">
            <button type="submit" class="rounded-lg border-[1.5px] border-black/[0.09] bg-white/70 px-5 py-2.5 font-dm text-[13px] font-medium text-[#4a4540] backdrop-blur-sm transition-all duration-150 hover:border-black/20 hover:text-[#141210] dark:border-white/[0.08] dark:bg-[#1e1c18]/70 dark:text-[#b8b0a5] dark:hover:border-white/20 dark:hover:text-[#f0ede8]">Quickly Search</button>
            <button data-random-search type="button" class="rounded-lg border-[1.5px] border-black/[0.09] bg-white/70 px-5 py-2.5 font-dm text-[13px] font-medium text-[#4a4540] backdrop-blur-sm transition-all duration-150 hover:border-black/20 hover:text-[#141210] dark:border-white/[0.08] dark:bg-[#1e1c18]/70 dark:text-[#b8b0a5] dark:hover:border-white/20 dark:hover:text-[#f0ede8]">Feeling Fast</button>
          </div>
        </form>

        <div class="mt-8 flex animate-fade-up delay-2 flex-wrap justify-center gap-2">
          {chips.map((chip) => <a href={`/results?q=${encodeURIComponent(chip)}`} class="rounded-full border-[1.5px] border-black/[0.09] px-3.5 py-1.5 font-dm text-xs font-medium text-[#8a837a] transition-all duration-150 hover:border-[var(--accent)] hover:text-[var(--accent)] dark:border-white/[0.08] dark:text-[#6e6760]">{chip}</a>)}
        </div>

        <p class="mt-10 animate-fade-up delay-3 text-[11px] text-[#8a837a]/60 dark:text-[#6e6760]/60">
          Press <kbd class="rounded bg-black/[0.06] px-1.5 py-0.5 font-mono text-[10px] dark:bg-white/[0.06]">Enter</kbd> or click the search button to search
        </p>
      </main>

      <footer class="flex flex-wrap items-center justify-between gap-2 border-t border-black/[0.07] px-7 py-4 text-xs text-[#8a837a] dark:border-white/[0.06] dark:text-[#6e6760]">
        <span>© 2026 Quickly Inc.</span>
        <div class="flex gap-5">
          {["Privacy", "Terms", "About", "Advertising"].map((link) => <a href="#" class="transition-colors duration-150 hover:text-[#141210] dark:hover:text-[#f0ede8]">{link}</a>)}
        </div>
      </footer>
    </div>
    <script is:inline src="/quickly.js"></script>
  </body>
</html>
